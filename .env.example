# Copy this file to `.env` and fill in your values.

# ── DeepSeek API ──────────────────────────────────────────────────────────────
DEEPSEEK_API_KEY=sk-your-key-here

# ── Target repo(s) to index ───────────────────────────────────────────────────
# Use REPO_PATHS for multiple repos (comma-separated, forward slashes on Windows).
# Use REPO_PATH for a single repo. REPO_PATHS takes priority when both are set.
REPO_PATHS=C:/My_Projects/Aelvyris,C:/My_Projects/Aelvyris-Backend,C:/My_Projects/Aelvyris-frontend,C:/My_Projects/aelvyris-deploy

# ── Proxy server ──────────────────────────────────────────────────────────────
PROXY_PORT=8000

# ── Embedding model ───────────────────────────────────────────────────────────
# Options:
#   BAAI/bge-m3              - highest quality, 1024-dim, ~2.2GB VRAM  (use EMBED_BATCH_SIZE=8)
#   BAAI/bge-small-en-v1.5   - fast, English, 384-dim, ~130MB VRAM    (use EMBED_BATCH_SIZE=32)
# Default is bge-small-en-v1.5 because it leaves plenty of headroom on a 4GB GTX 1650.
EMBED_MODEL=BAAI/bge-small-en-v1.5
EMBED_BATCH_SIZE=32

# ── Retrieval tuning ──────────────────────────────────────────────────────────
# Hybrid search fuses BM25 (keyword) + vector (semantic) results via RRF.
# Set HYBRID_ALPHA=1.0 for pure vector, 0.0 for pure BM25, 0.5 for even mix.
HYBRID_ALPHA=0.5
TOP_K_CHUNKS=12
MIN_RELEVANCE_SCORE=0.22
TOKEN_BUDGET=18000

# ── Logging: DEBUG | INFO | WARNING | ERROR ──────────────────────────────────
LOG_LEVEL=INFO
